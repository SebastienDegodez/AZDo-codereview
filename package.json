{
  "name": "azure-devops-openai-review",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "review": "node azuredevops-openai-review.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=integration"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "openai": "^4.40.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}

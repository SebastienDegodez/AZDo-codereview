{
  "name": "@sebastiendegodez/azdo-codereview",
  "version": "1.1.0",
  "type": "module",
  "description": "Azure DevOps Code Review automation using OpenAI",
  "main": "azuredevops-openai-review.js",
  "bin": {
    "azdo-codereview": "azuredevops-openai-review.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "src/",
    "azuredevops-openai-review.js"
  ],
  "keywords": [
    "azure-devops",
    "code-review",
    "openai",
    "automation",
    "ai",
    "pull-request"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SebastienDegodez/AZDo-codereview.git"
  },
  "homepage": "https://github.com/SebastienDegodez/AZDo-codereview#readme",
  "bugs": {
    "url": "https://github.com/SebastienDegodez/AZDo-codereview/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "review": "node azuredevops-openai-review.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=integration",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=unit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "openai": "^4.77.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@microcks/microcks-testcontainers": "^0.3.0",
    "jest": "^29.7.0",
    "testcontainers": "^10.16.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 120000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
